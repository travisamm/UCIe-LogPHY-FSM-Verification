// Coverage Configuration File for MBINIT simulation.
// Passed to xrun via -covfile.

// Exclude mbinit_state_sync_sva from all coverage metrics.
// This module is intentionally unbound (see XC-03 comment in logphy_sva.sv):
// the one-cycle resync property is too tight for the current RTL substate timing.
check -name {a_state_sync} -module {mbinit_state_sync_sva} -off
